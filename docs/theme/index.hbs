<!DOCTYPE HTML>
<html lang="{{ language }}" class="no-js">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="generator" content="mdBook {{ mdbook_version }}">
        
        <title>{{ title }}</title>
        
        <base href="{{ path_to_root }}">
        
        <link rel="preload" href="fontawesome-free-5.15.4-web/css/all.min.css" as="style">
        <link rel="preload" href="fonts/open-sans.all.css" as="style">
        
        <link rel="stylesheet" href="fontawesome-free-5.15.4-web/css/all.min.css">
        <link rel="stylesheet" href="fonts/open-sans.all.css">
        <link rel="stylesheet" href="css/variables.css">
        <link rel="stylesheet" href="css/general.css">
        <link rel="stylesheet" href="css/chrome.css">
        <link rel="stylesheet" href="css/print.css" media="print">
        
        <!-- Catppuccin theme CSS -->
        <link rel="stylesheet" href="{{ path_to_root }}catppuccin.css">
        
        {{#if print_enable}}
        <link rel="stylesheet" href="css/print.css" media="print">
        {{/if}}

        <link rel="icon" type="image/svg+xml" href="{{ path_to_root }}favicon.svg">
    </head>
    <body class="sidebar-visible no-js">
        <div id="body-container">
            <header>
                <div id="heading-container">
                    <a href="{{ path_to_root }}" title="{{ title }}" class="logo">
                        <span class="logo-icon">🦀</span>
                    </a>
                    <h1 class="header-title">{{ title }}</h1>
                    <h2 class="version">{{ version }}</h2>
                </div>
                <div id="menu-bar">
                    <div id="menu-bar-sticky-container">
                        <div class="left-buttons">
                            <button id="sidebar-toggle" class="icon-button" title="Toggle Table of Contents" aria-label="Toggle Table of Contents">
                                <i class="fa fa-bars"></i>
                            </button>
                            <button id="theme-toggle" class="icon-button" title="light (Alt+1)" aria-label="Toggle light/dark">
                                <i class="fa fa-sun"></i>
                            </button>
                        </div>

                        <nav class="menu-bar-table">
                            <span class="left-buttons">
                                <span id="page-nav-section">
                                    {{#if previous}}
                                    <a rel="prev" href="{{ previous }}" class="mobile-menu-chapter">
                                        <i class="fa fa-chevron-left"></i>
                                    </a>
                                    {{/if}}
                                    {{#if next}}
                                    <a rel="next" href="{{ next }}" class="mobile-menu-chapter">
                                        <i class="fa fa-chevron-right"></i>
                                    </a>
                                    {{/if}}
                                </span>
                            </span>
                            <span class="right-buttons">
                                <a href="{{ path_to_root }}print.html" title="{{ print_text }}" class="header-button">
                                    <i class="fa fa-print"></i>
                                </a>
                                <a href="https://github.com/JeremySomsouk/review-dispatcher" title="GitHub" class="header-button">
                                    <i class="fab fa-github"></i>
                                </a>
                            </span>
                        </nav>
                    </div>
                </div>
            </header>
            
            <div class="theme-popup-wrapper">
                <div class="theme-popup">
                    <span class="theme-options-label">Theme</span>
                    <div class="theme-name-wrapper">
                        <input type="radio" id="light-os" name="theme" value="light" class="theme-option">
                        <label for="light-os">Light (OS)</label>
                    </div>
                    <div class="theme-name-wrapper">
                        <input type="radio" id="latte" name="theme" value="latte" class="theme-option">
                        <label for="latte">Latte</label>
                    </div>
                    <div class="theme-name-wrapper">
                        <input type="radio" id="frappe" name="theme" value="frappe" class="theme-option">
                        <label for="frappe">Frappé</label>
                    </div>
                    <div class="theme-name-wrapper">
                        <input type="radio" id="macchiato" name="theme" value="macchiato" class="theme-option">
                        <label for="macchiato">Macchiato</label>
                    </div>
                    <div class="theme-name-wrapper">
                        <input type="radio" id="mocha" name="theme" value="mocha" class="theme-option">
                        <label for="mocha">Mocha</label>
                    </div>
                </div>
            </div>

            <div id="content-wrapper">
                <main>
                    {{{ content }}}
                </main>
                <nav class="nav-wrapper">
                    <nav class="nav-pills" id="toc">
                        <label class="toc-label">Table of Contents</label>
                        {{> toc}}
                    </nav>
                </nav>
            </div>

            <footer>
                <p class="footer-text">
                    Built with 🦀 <a href="https://github.com/JeremySomsouk/review-dispatcher">Review Dispatcher</a>
                </p>
            </footer>
        </div>

        <script src="ElasticLunr.js"></script>
        <script src="mark.min.js"></script>
        <script src="searcher.js"></script>
        <script src="clipboard.min.js"></script>
        <script src="highlight.js"></script>
        <script src="book.js"></script>
        
        <script>
            var defaultTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "mocha" : "light-os";
            
            var theme;
            (function() {
                const storedTheme = localStorage.getItem("mdbook-theme");
                if (storedTheme === null) {
                    theme = defaultTheme;
                } else {
                    theme = storedTheme;
                }
            })();
            
            var html = document.querySelector("html");
            html.classList.remove("no-js")
            html.classList.remove("light")
            html.classList.remove("dark")
            html.classList.add(theme);
            var body = document.querySelector("body");
            if (theme === "light-os") {
                body.classList.remove("dark");
            } else {
                body.classList.remove("light");
                body.classList.add(theme);
            }

            var sidebar = document.getElementById("sidebar");
            var sidebarToggle = document.getElementById("sidebar-toggle");
            sidebar.addEventListener('click', function(event) {
                if (event.target.tagName === "A" || event.target.parentElement.tagName === "A") {
                    sidebar.classList.add("hidden");
                }
            });
            sidebarToggle.addEventListener("click", function(event) {
                event.preventDefault();
                if (sidebar.classList.contains("hidden")) {
                    sidebar.classList.remove("hidden");
                } else {
                    sidebar.classList.add("hidden");
                }
            });

            var themeToggle = document.getElementById("theme-toggle");
            themeToggle.addEventListener("click", function(event) {
                event.preventDefault();
                var currentTheme = html.classList.contains("light") ? "light" : "dark";
                var newTheme;
                if (currentTheme === "light") {
                    newTheme = "mocha";
                } else {
                    newTheme = "light-os";
                }
                html.classList.remove(currentTheme);
                html.classList.add(newTheme);
                body.classList.remove(currentTheme);
                body.classList.add(newTheme);
                localStorage.setItem("mdbook-theme", newTheme);
            });

            // Handle radio buttons for theme selection
            var themeOptions = document.querySelectorAll('.theme-option');
            themeOptions.forEach(function(option) {
                option.addEventListener('change', function(event) {
                    var selectedTheme = event.target.value;
                    var currentTheme = html.classList.contains("light") ? "light" : "dark";
                    html.classList.remove(currentTheme);
                    html.classList.add(selectedTheme);
                    body.classList.remove(currentTheme);
                    body.classList.add(selectedTheme);
                    localStorage.setItem("mdbook-theme", selectedTheme);
                });
            });
        </script>
    </body>
</html>
