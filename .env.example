# PRCtrl Configuration
# 
# NEW USERS: Run `prctrl config init` for interactive setup
# 
# This file is for CI/automation use cases.
# Values here override ~/.prctrl/config.toml

# Required
RD_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
RD_GITHUB_USERNAME=your-username
RD_GITHUB_ORG=your-org

# Optional
RD_GITHUB_REPOS=owner/repo1,owner/repo2
RD_GITHUB_TEAMS=team-slug
RD_CREW_MEMBERS=user1,user2
RD_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
